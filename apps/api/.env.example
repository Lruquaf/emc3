# ═══════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════
DATABASE_URL="postgresql://emc3_user:emc3_local_pass@localhost:5432/emc3_dev"

# ═══════════════════════════════════════════════════════════
# AUTH & SECURITY
# ═══════════════════════════════════════════════════════════
JWT_SECRET="change-this-to-a-secure-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
COOKIE_DOMAIN="localhost"
COOKIE_SECURE="false"

# ═══════════════════════════════════════════════════════════
# EMAIL
# Local: Mailhog (SMTP). Production: Brevo HTTP API (BREVO_API_KEY).
# ═══════════════════════════════════════════════════════════
# Production (Brevo) - uygulama bu değişkeni kullanır
# BREVO_API_KEY=""
EMAIL_FROM="noreply@emc3.local"
# Local SMTP (Mailhog) - opsiyonel
# SMTP_HOST="localhost"
# SMTP_PORT="1025"
# SMTP_USER=""
# SMTP_PASS=""

# ═══════════════════════════════════════════════════════════
# GOOGLE OAUTH
# ═══════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# ═══════════════════════════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════════════════════════
NODE_ENV="development"
PORT="3000"
FRONTEND_URL="http://localhost:5173"
API_URL="http://localhost:3000"

# ═══════════════════════════════════════════════════════════
# İLK ADMIN (Sadece production ilk kurulum)
# RUN_INITIAL_ADMIN_SCRIPT=true + INITIAL_ADMIN_EMAIL + INITIAL_ADMIN_PASSWORD
# ile deploy edin; ilk girişten sonra false yapın ve şifreyi kaldırın.
# ═══════════════════════════════════════════════════════════
# RUN_INITIAL_ADMIN_SCRIPT="false"
# INITIAL_ADMIN_EMAIL=""
# INITIAL_ADMIN_PASSWORD=""
# INITIAL_ADMIN_USERNAME=""
# INITIAL_ADMIN_DISPLAY_NAME="Platform Admin"

# ═══════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED="false"

# ═══════════════════════════════════════════════════════════
# CLOUDINARY
# ═══════════════════════════════════════════════════════════
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
